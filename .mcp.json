{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "node",
      "args": [
        "/usr/lib/node_modules/@playwright/mcp/cli.js",
        "--config=/workspace/.claude/playwright-config.json"
      ],
      "env": {
        "PLAYWRIGHT_BROWSERS_PATH": "/opt/ms-playwright"
      }
    }
  }
}